{
	"name": "@lesjoursfr/mastodon-share-button",
	"version": "4.0.0",
	"description": "Simple module to share content to Mastodon.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lesjoursfr/mastodon-share-button.git"
	},
	"homepage": "https://github.com/lesjoursfr/mastodon-share-button#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/mastodon-share-button/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "22.x || 24.x"
	},
	"browserslist": [
		"Chrome >= 60",
		"Safari >= 12",
		"iOS >= 12",
		"Firefox >= 60",
		"Edge >= 79"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"eslint-check": "eslint",
		"eslint-fix": "eslint --fix",
		"stylelint-check": "stylelint **/*.scss",
		"stylelint-fix": "stylelint **/*.scss --fix",
		"prettier-check": "prettier --check .",
		"prettier-fix": "prettier --write .",
		"test": "NODE_OPTIONS='--loader=ts-node/esm' mocha",
		"build-esm": "tsc && node assets.js",
		"build-browser": "webpack --mode production --config ./server/webpack.config.js --progress",
		"build": "npm run build-esm && npm run build-browser",
		"builddeps": "webpack --mode production --config server/deps/codemirror.webpack.js --progress",
		"server": "webpack serve --mode development --config ./server/webpack.config.js --hot --open"
	},
	"keywords": [
		"mastodon",
		"share",
		"button"
	],
	"dependencies": {
		"@lesjoursfr/browser-tools": "^3.1.2"
	},
	"devDependencies": {
		"@babel/core": "7.29.0",
		"@babel/preset-env": "7.29.2",
		"@eslint/js": "10.0.1",
		"@tsconfig/next": "2.0.6",
		"@types/babel__core": "7.20.5",
		"@types/babel__preset-env": "7.10.0",
		"@types/node": "24.12.2",
		"@types/webpack-env": "1.18.8",
		"babel-loader": "10.1.1",
		"css-loader": "7.1.4",
		"css-minimizer-webpack-plugin": "8.0.0",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"fs-extra": "11.3.4",
		"globals": "17.5.0",
		"jsdom": "29.0.2",
		"mini-css-extract-plugin": "2.10.2",
		"postcss": "8.5.10",
		"prettier": "3.8.3",
		"sass": "1.99.0",
		"sass-loader": "16.0.7",
		"stylelint": "17.9.0",
		"stylelint-config-standard-scss": "17.0.0",
		"terser-webpack-plugin": "5.5.0",
		"ts-loader": "9.5.7",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.0",
		"webpack": "5.106.2",
		"webpack-cli": "7.0.2",
		"webpack-dev-server": "5.2.3"
	},
	"dependenciesMeta": {
		"@parcel/watcher": {
			"built": true
		}
	},
	"packageManager": "yarn@4.14.1"
}
